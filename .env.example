# ─── Database ────────────────────────────────────────────────────────────────
# Postgres connection string used by the FastAPI backend and the loaders.
DATABASE_URL=postgresql://user:password@localhost:5432/belgian_companies

# ─── NBB CBSO API ────────────────────────────────────────────────────────────
# Separate keys per NBB subscription type (preferred).
# Get these from the NBB developer portal: https://ws.cbso.nbb.be
NBB_AUTHENTIC_KEY=your_authentic_data_key_here
NBB_EXTRACT_KEY=your_extract_key_here
# NBB_ARCHIVE_KEY is reserved for archive endpoints (not yet used by code).
# NBB_API_KEY is the legacy single-key fallback — only needed if you don't
# have separate keys yet. The code prefers the specific keys above.
# NBB_API_KEY=your_primary_key_here
# Test: https://ws.uat2.cbso.nbb.be   Production: https://ws.cbso.nbb.be
NBB_BASE_URL=https://ws.cbso.nbb.be

# ─── Supabase (server-side JWT verification) ─────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# JWKS endpoint used by the backend to verify Supabase-issued JWTs.
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/keys

# ─── Supabase (client-side, baked into Next.js build) ────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# ─── Clerk (Phase 2: SDK installed; toggle ON via NEXT_PUBLIC_USE_CLERK=true) ──
# Default OFF — production keeps running Supabase auth until Phase 5/6 cutover.
# When set to "true", proxy.ts activates clerkMiddleware() and layout.tsx
# wraps the tree in <ClerkProvider>. See docs/auth-migration-clerk-final.md.
NEXT_PUBLIC_USE_CLERK=false
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ─── Clerk (Phase 3: backend JWT verification + webhook) ─────────────────────
# Backend verifies Clerk-issued JWTs (RS256, JWKS-cached) when the JWT's
# `iss` claim matches CLERK_ISSUER. Leaving CLERK_ISSUER empty disables
# the Clerk verification path entirely (Supabase JWTs continue to work).
# CLERK_JWKS_URL defaults to <CLERK_ISSUER>/.well-known/jwks.json when unset.
# CLERK_AUTHORIZED_PARTY is optional; when set, JWT `azp` must match.
# CLERK_WEBHOOK_SECRET is the Svix signing secret for /api/_auth/clerk-webhook.
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUTHORIZED_PARTY=
CLERK_WEBHOOK_SECRET=whsec_xxx

# ─── API URLs ────────────────────────────────────────────────────────────────
# Browser-facing API base URL (empty string = same origin via nginx).
NEXT_PUBLIC_API_URL=
# Internal URL used by the Next.js server for SSR fetches.
API_URL_INTERNAL=http://backend:8000

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Third-party services ────────────────────────────────────────────────────
# AI enrichment (summarisation, entity extraction).
OPENROUTER_API_KEY=sk-or-xxx
# Optional Ollama Cloud routing for selected LLM calls.
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=ollama_xxx
# Optional bulk semantic-enrichment routing. Use `ollama:<tag>` for first pass;
# fallback keeps quality stable on timeout/parse failure.
# BULK_Q2_MODEL=ollama:qwen3-coder-next
# BULK_Q2_FALLBACK_MODEL=openai/gpt-4o-mini
# BULK_HAIKU_MODEL=anthropic/claude-haiku-4.5
# BULK_HAIKU_FALLBACK_MODEL=
# Known latest EBITDA below this floor bypasses discovery + LLM work and
# goes straight to the deterministic fast lane.
SEMANTIC_FASTLANE_EBITDA_FLOOR=200000
# Proxied web scraping. Zenrows was disabled on 2026-04-25 and replaced by
# the in-network playwright-scraper service (see playwright-scraper/ +
# docker-compose.yml). The Zenrows env var is no longer required and can
# be left unset; if present it is ignored. The playwright service reads
# its proxy list from the same WEBSHARE_PROXIES_FILE path defined below.
# ZENROWS_API_KEY=your_zenrows_key

# ─── Staatsblad structured-event extraction (Stage 3) ────────────────────────
# Direct Anthropic key — used by the batch-API backfill and the daily
# incremental extractor. Distinct from OPENROUTER_API_KEY (the batch API
# is not available through OpenRouter).  Required for Phase 4a backfill.
ANTHROPIC_API_KEY=sk-ant-xxx

# ─── Optional infra ──────────────────────────────────────────────────────────
# Redis is optional — only needed when scaling the backend beyond one
# instance (rate limits / usage counters move out of process memory).
REDIS_URL=redis://localhost:6379/0

# ─── Backend server binding ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# API_RELOAD=false   # set to true for dev hot-reload (uvicorn reload mode)

# ─── Privacy ─────────────────────────────────────────────────────────────────
# Random secret used to HMAC anonymous IPs before they hit the activity log.
# Rotate to invalidate historical anon-IP correlation. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
ACTIVITY_LOG_IP_SALT=change_me_to_a_long_random_string

# ─── Webshare rotating proxies (shared by all bulk scrapers) ────────────────
# Used by:
#   - scripts/staatsblad_bulk_scrape.py --mode=webshare
#   - playwright-scraper/server.py (semantic worker + on-profile retry)
# Sign up at webshare.io (entry plan ~$3/mo, 100 rotating DC proxies).
# Download the proxy list via Dashboard → Proxy → Download, save at this
# path. Format: one IP:PORT:USER:PASS per line.
WEBSHARE_PROXIES_FILE=/root/webshare_proxies.txt

# ─── Playwright scraper service tuning ──────────────────────────────────────
# Defaults are sane; tune only if you see RAM pressure or slow scrapes.
# PLAYWRIGHT_MAX_CONCURRENT=3        # concurrent Chromium contexts
# PLAYWRIGHT_DEFAULT_TIMEOUT_MS=30000 # per-page navigation timeout
# PLAYWRIGHT_RECYCLE_AFTER=500       # full Chromium relaunch every N requests
# Dedicated worker defaults. BULK_MAX_PAGES controls how many Staatsblad
# result pages the bulk worker will traverse per company. The worker logs
# to STAATSBLAD_BULK_LOG_DIR on the host so progress survives container
# replacement and can be tailed outside Docker.
BULK_MAX_PAGES=5
STAATSBLAD_BULK_WORKERS=10
STAATSBLAD_BULK_LOG_DIR=/var/log/staatsblad_bulk
