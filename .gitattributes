# Force LF for files that must execute on Linux. Without this, Windows
# clones can commit CRLF for unknown extensions and break shell/systemd
# parsing.
*.sh        text eol=lf
*.service   text eol=lf
*.timer     text eol=lf
*.path      text eol=lf
*.socket    text eol=lf
*.target    text eol=lf
*.mount     text eol=lf
*.conf      text eol=lf
Makefile    text eol=lf
*.py        text eol=lf
